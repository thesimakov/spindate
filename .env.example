# Пример переменных окружения (скопируйте в .env.local)

# Несколько инстансов Next.js: общее состояние столов и игры (Redis).
# Если не задано — используется память процесса (только один инстанс).
# REDIS_URL=redis://127.0.0.1:6379/0

# VK Mini App (клиент): ID приложения из настроек VK.
# NEXT_PUBLIC_VK_APP_ID=54511363

# Опционально: кнопка «Новость сообщества» в профиле (VKWebAppOpenWallPost) — owner_id и post_id записи на стене (см. URL записи ВК).
# NEXT_PUBLIC_VK_OPEN_WALL_OWNER_ID=-123456789
# NEXT_PUBLIC_VK_OPEN_WALL_POST_ID=12345

# Защищённый ключ приложения — для проверки подписи уведомлений на /api/vk/payments (совпадает с полем в настройках VK).
# VK_PAYMENTS_SECRET=

# Тот же защищённый ключ: автоматический вход в мини-приложении (POST /api/auth/vk). Если не задан — используется VK_PAYMENTS_SECRET.
# VK_MINI_APP_SECRET=

# Сервисный ключ доступа (настройки приложения ВК → «Сервисный ключ») для отправки оповещений игрокам через API notifications.sendMessage.
# Без ключа сервер не шлёт push; в клиенте всё равно можно запросить разрешение через VKWebAppAllowNotifications.
# Также нужен для проверки подписки на сообщество (groups.isMember) при бонусе «мобильный экран».
# VK_SERVICE_ACCESS_TOKEN=

# Экран «мобильная версия недоступна»: по умолчанию включён. Отключить: NEXT_PUBLIC_MOBILE_APP_BLOCKED=0
# NEXT_PUBLIC_MOBILE_APP_BLOCKED=1

# Статическая сборка (GitHub Pages): базовый URL API на сервере с next start (см. workflow nextjs.yml).
# NEXT_PUBLIC_API_BASE_URL=https://spindate.lemnity.ru

# На сервере: дополнительные Origin для CORS к /api/* (через запятую), например форк Pages.
# CORS_ALLOWED_ORIGINS=https://user.github.io

# Уведомления админу в Telegram при новом объявлении в тикере (на модерацию). Оба ключа обязательны для отправки.
# Бот: @BotFather → токен. chat_id: личный id (@userinfobot) или id группы (часто начинается с -100…).
# TELEGRAM_ADMIN_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=
