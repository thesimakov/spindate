# Пример переменных окружения (скопируйте в .env.local)

# Несколько инстансов Next.js: общее состояние столов и игры (Redis).
# Если не задано — используется память процесса (только один инстанс).
# REDIS_URL=redis://127.0.0.1:6379/0

# VK Mini App (клиент): ID приложения из настроек VK.
# NEXT_PUBLIC_VK_APP_ID=54483214

# Защищённый ключ приложения — для проверки подписи уведомлений на /api/vk/payments (совпадает с полем в настройках VK).
# VK_PAYMENTS_SECRET=

# Тот же защищённый ключ: автоматический вход в мини-приложении (POST /api/auth/vk). Если не задан — используется VK_PAYMENTS_SECRET.
# VK_MINI_APP_SECRET=
